# Public API base — must include /api (Express mounts routes under /api)
#
# Local (backend default PORT=5050):
# NEXT_PUBLIC_API_BASE_URL=http://localhost:5050/api
#
# Production (Railway) — required on Vercel Production env, then Redeploy:
NEXT_PUBLIC_API_BASE_URL=https://ieltshabibv1backend-production.up.railway.app/api

# Public site URL (browser / redirects / metadata)
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Production:
# NEXT_PUBLIC_APP_URL=https://gamlish.com

# Optional server-only upstream override for Next rewrites / RSC:
# API_UPSTREAM_URL=https://ieltshabibv1backend-production.up.railway.app/api

# CRITICAL: must match backend JWT_SECRET exactly (Vercel ↔ Railway)
# Without this, login "works" then tab-return / middleware treats the user as logged out.
JWT_SECRET=use-a-long-random-string-same-as-backend

# Optional: YouTube video ID for guest landing
# NEXT_PUBLIC_GAMLISH_HOW_IT_WORKS_VIDEO_ID=

# bKash number shown at checkout when plan instructions omit it
# NEXT_PUBLIC_BKASH_NUMBER=01XXXXXXXXX

# Dev only — never enable in production
# DISABLE_MIDDLEWARE_AUTH_REDIRECT=true
