# Public API base — must include /api (Express mounts routes under /api)
#
# Local (backend default PORT=5050):
# NEXT_PUBLIC_API_BASE_URL=http://localhost:5050/api
#
# Production (Railway):
NEXT_PUBLIC_API_BASE_URL=https://ieltshabibv1backend-production.up.railway.app/api

# Public site URL (browser / redirects). Local:
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Production (Vercel etc.) — use your live custom domain when you have one:
# NEXT_PUBLIC_APP_URL=https://gamlish.com

# Browser API calls go through /api/backend (same-origin). The proxy forwards to Railway using
# NEXT_PUBLIC_API_BASE_URL above. Optional server-only override:
# API_UPSTREAM_URL=https://ieltshabibv1backend-production.up.railway.app/api

# Must match backend JWT_SECRET (server-side verification in middleware / RSC)
JWT_SECRET=use-a-long-random-string-same-as-backend

# Never set in production unless debugging auth redirects
# DISABLE_MIDDLEWARE_AUTH_REDIRECT=true
